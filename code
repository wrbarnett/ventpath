def safe_log1p_target(y: pd.Series) -> pd.Series:
    return np.log1p(y.clip(lower=0))


@st.cache_resource
def train_model(csv_path: str = "fent26_final.csv"):
    df = pd.read_csv(csv_path)

    numeric_candidates = list(set(FEATURE_COLS + [TARGET_COL, "vent_days"] + RAW_PARALYTIC_COLS))
    for col in numeric_candidates:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors="coerce")

    # Derive transformed variables from raw columns if they are not already present.
    available_paralytic_cols = [c for c in RAW_PARALYTIC_COLS if c in df.columns]

    if "total_paralytic_days" not in df.columns:
        if available_paralytic_cols:
            for col in available_paralytic_cols:
                df[col] = df[col].fillna(0)
            df["total_paralytic_days"] = df[available_paralytic_cols].sum(axis=1)
        else:
            df["total_paralytic_days"] = 0.0

    if "any_paralytic" not in df.columns:
        df["any_paralytic"] = (df["total_paralytic_days"].fillna(0) > 0).astype(int)

    # Restrict to ventilated patients, as in your analysis.
    if "vent_days" not in df.columns:
        raise ValueError("The CSV must contain a 'vent_days' column.")

    df = df[df["vent_days"].fillna(0) > 0].copy()
    df = df[df[TARGET_COL] > 0].copy()

    # Ensure all required feature columns exist after derivation.
    missing_features = [c for c in FEATURE_COLS if c not in df.columns]
    if missing_features:
        raise ValueError(f"The CSV is missing required columns: {missing_features}")

    # Binary cleanup.
    for col in BINARY_COLS:
        if col in df.columns:
            df[col] = df[col].fillna(0)
            df[col] = (df[col] > 0).astype(int)

    model_df = df[FEATURE_COLS + [TARGET_COL]].copy()

    X = model_df[FEATURE_COLS]
    y = safe_log1p_target(model_df[TARGET_COL])

    preprocessor = ColumnTransformer(
        transformers=[
            (
                "num",
                Pipeline([
                    ("imputer", SimpleImputer(strategy="median")),
                ]),
                NUMERIC_COLS,
            )
        ],
        remainder="drop",
    )

    model = GradientBoostingRegressor(
        n_estimators=300,
        learning_rate=0.05,
        max_depth=3,
        random_state=42,
    )

    pipe = Pipeline([
        ("prep", preprocessor),
        ("model", model),
    ])
    pipe.fit(X, y)

    summary = {
        "n": int(len(model_df)),
        "target_median": float(df[TARGET_COL].median()),
        "target_q1": float(df[TARGET_COL].quantile(0.25)),
        "target_q3": float(df[TARGET_COL].quantile(0.75)),
    }
    return pipe, summary


